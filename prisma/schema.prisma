generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============== MULTI-TENANT MODELS ==============

// Organization (Tenant)
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  email     String?
  phone     String?
  address   String?
  city      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Subscription
  planId        String?
  plan          SubscriptionPlan? @relation(fields: [planId], references: [id])
  planStartDate DateTime @default(now())
  planEndDate   DateTime?
  subscriptionStatus String @default("ACTIVE") // ACTIVE, SUSPENDED, CANCELLED, EXPIRED
  billingCycle  String   @default("MONTHLY") // MONTHLY, YEARLY
  
  // Current active subscription (for revenue tracking)
  subscriptionId String?
  subscription   Subscription? @relation("ActiveSubscription", fields: [subscriptionId], references: [id])
  
  // Relations
  users         User[]
  residences    Residence[]
  subscriptions Subscription[] @relation("OrganizationSubscriptions")
}

// Subscription Plan
model SubscriptionPlan {
  id          String   @id @default(cuid())
  name        String   // Starter, Pro, Enterprise
  slug        String   @unique
  description String?
  price       Float    // Monthly price in MAD
  yearlyPrice Float?   // Yearly price in MAD
  billingCycle String   @default("MONTHLY") // MONTHLY, YEARLY
  features    String   // JSON string of features
  maxResidences Int    @default(1)
  maxAdmins     Int    @default(1)
  maxApartments Int    @default(50)
  maxResidents  Int    @default(100)
  hasAdvancedReports Boolean @default(false)
  hasPrioritySupport Boolean @default(false)
  hasApiAccess   Boolean @default(false)
  isActive      Boolean @default(true)
  isVisible     Boolean @default(true)  // Show on landing page
  isPopular     Boolean @default(false) // Highlight as popular
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  subscriptionRequests SubscriptionRequest[]
  organizations Organization[]
  subscriptions Subscription[] @relation("OrganizationSubscriptions")
}

// Subscription - tracks active subscriptions
model Subscription {
  id            String   @id @default(cuid())
  organizationId String
  organization  Organization @relation("OrganizationSubscriptions", fields: [organizationId], references: [id], onDelete: Cascade)
  planId        String?
  plan          SubscriptionPlan? @relation(fields: [planId], references: [id])
  billingCycle  String   // MONTHLY, YEARLY
  price         Float    // Price in MAD
  status        String   @default("ACTIVE") // ACTIVE, SUSPENDED, CANCELLED, EXPIRED
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  payments Payment[]
}

// Residence (Building complex)
model Residence {
  id          String   @id @default(cuid())
  name        String
  address     String
  city        String
  postalCode  String?
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Additional fields
  numberOfBuildings    Int?    // Number of buildings in the residence
  numberOfApartments  Int?    // Total number of apartments
  contactPhone        String? // Contact phone for the residence
  email              String? // Contact email for the residence
  notes              String? // Additional notes
  status             String  @default("ACTIVE") // ACTIVE, INACTIVE, MAINTENANCE

  // Tenant relation
  organizationId String
  organization  Organization @relation(fields: [organizationId], references: [id])

  // Relations
  admins       Admin[]
  apartments   Apartment[]
  expenses     Expense[]
  charges     Charge[]
  maintenanceRequests MaintenanceRequest[]
  announcements Announcement[]
  documents    Document[]

  // For ADMIN users who manage this residence
  adminUsers User[] @relation("AdminResidence")
}

// User (can be OWNER, ADMIN, or RESIDENT linked to Apartment)
// 
// Role Scoping Rules:
// - OWNER: Global platform admin - NOT tied to any residence, can see ALL residences
// - ADMIN: Syndic/Manager - MUST be linked to exactly ONE residence via adminForResidenceId
// - RESIDENT: Apartment resident - linked to exactly ONE apartment via apartmentId
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("RESIDENT") // OWNER, ADMIN, RESIDENT
  phone     String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Tenant relation (required for all users)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // For ADMIN role - REQUIRED: must be linked to exactly ONE Residence
  // This enforces that ADMIN cannot exist without an assigned residence
  // and cannot manage multiple residences
  adminForResidenceId String? 
  adminForResidence   Residence? @relation("AdminResidence", fields: [adminForResidenceId], references: [id])

  // For RESIDENT role - linked to an Apartment (unique for one-to-one)
  apartmentId String? @unique
  apartment   Apartment? @relation("ResidentApartment", fields: [apartmentId], references: [id])

  // Relations
  admins              Admin[]
  maintenanceRequests MaintenanceRequest[]
  announcements       Announcement[]
  uploadedDocuments   Document[]
}

// Admin profile (specific to a Residence)
model Admin {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  residenceId String
  residence   Residence @relation(fields: [residenceId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([userId, residenceId])
}

// Apartment (within a Residence)
model Apartment {
  id          String   @id @default(cuid())
  number      String   // Apartment number (e.g., "A12", "B4")
  floor       Int?
  building    String?  // Building block (A, B, C)
  type        String   @default("T2") // T1, T2, T3, T4, Studio
  status      String   @default("VACANT") // OCCUPIED, VACANT
  area        Float?   // Size in sqm
  bedrooms    Int      @default(1)
  bathrooms   Int      @default(1)
  rentAmount  Float?   // Monthly rent
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Occupancy tracking
  occupancyType      String?  // OWNER_OCCUPIED, RENTED
  currentOccupantName String?
  currentOccupantPhone String?
  moveInDate        DateTime?
  moveOutDate       DateTime?

  // Relations
  residenceId String
  residence   Residence @relation(fields: [residenceId], references: [id])

  residentUser User? @relation("ResidentApartment")
  payments     Payment[]
  charges     Charge[]
  maintenanceRequests MaintenanceRequest[]
  occupancyHistory   ApartmentOccupancyHistory[]
  apartmentHistory   ApartmentHistory[]
  documents          Document[]

  @@unique([residenceId, number])
}

// Apartment Occupancy History - tracks all occupants over time
model ApartmentOccupancyHistory {
  id            String   @id @default(cuid())
  occupantName  String
  occupantPhone String?
  occupancyType String  // OWNER_OCCUPIED, RENTED
  moveInDate   DateTime
  moveOutDate  DateTime?
  notes         String?
  createdAt    DateTime @default(now())

  // Relations
  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
}

// Apartment History - tracks events like complaints, modifications, etc.
model ApartmentHistory {
  id          String   @id @default(cuid())
  eventType   String   // OCCUPANT_CHANGE, COMPLAINT, ADMIN_MODIFICATION, MOVE_IN, MOVE_OUT, STATUS_CHANGE
  description String
  notes       String?
  createdAt  DateTime @default(now())

  // Optional link to related entities
  relatedUserId String?
  maintenanceRequestId String?

  // Relations
  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
}

// Charge (monthly charges for an apartment)
model Charge {
  id          String   @id @default(cuid())
  title       String
  category    String   // WATER, ELECTRICITY, ELEVATOR, CLEANING, SECURITY, OTHER
  amount      Float
  month       Int      // 1-12
  year        Int
  description String?
  dueDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  residenceId String
  residence   Residence @relation(fields: [residenceId], references: [id])
  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id])
  payments    Payment[]
}

// Payment
model Payment {
  id        String   @id @default(cuid())
  amount    Float
  status    String   @default("PENDING") // PENDING, PAID, OVERDUE
  method    String?  // CASH, CARD, TRANSFER, CHEQUE
  dueDate   DateTime
  paidDate  DateTime?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  apartmentId    String?
  apartment      Apartment? @relation(fields: [apartmentId], references: [id])
  chargeId       String?
  charge         Charge?    @relation(fields: [chargeId], references: [id])
  subscriptionId String?
  subscription   Subscription? @relation("SubscriptionPayments", fields: [subscriptionId], references: [id])
}

// Expense
model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  category    String
  date        DateTime
  receiptUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  residenceId String
  residence   Residence @relation(fields: [residenceId], references: [id])
}

// Maintenance Request
model MaintenanceRequest {
  id          String   @id @default(cuid())
  title       String
  description String
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED
  priority    String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  category    String?  // PLUMBING, ELECTRICAL, ELEVATOR, HVAC, OTHER
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  resolvedAt  DateTime?

  residenceId String
  residence   Residence @relation(fields: [residenceId], references: [id])
  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id])
  reportedById String
  reportedBy  User       @relation(fields: [reportedById], references: [id])
}

// Subscription Request - tracks subscription requests from potential clients
model SubscriptionRequest {
  id              String   @id @default(cuid())
  
  // Contact / Account Information
  fullName        String
  email           String
  phone           String
  passwordTemp    String?  // Optional temporary password chosen by user
  preferredLanguage String @default("fr") // fr, ar, en
  
  // Residence / Organization Information
  organizationName String
  residenceName   String
  address         String
  city            String
  country         String   @default("Maroc")
  numberOfBuildings Int    @default(1)
  numberOfFloors  Int      @default(1)
  numberOfApartments Int
  estimatedNumberOfResidents Int?
  
  // Subscription Information
  planId          String?
  plan            SubscriptionPlan? @relation(fields: [planId], references: [id])
  selectedPlanSlug String   // Store plan slug for reference
  billingCycle    String   @default("monthly") // monthly, yearly
  notes           String?
  
  // Optional Business Information
  ice             String?
  rc              String?
  taxId           String?
  website         String?
  
  // Payment Information
  paymentReference String   @unique // DRN-YYYYMMDD-XXXXXX
  bankTransferProofUrl String?
  bankTransferProofName String?
  bankTransferProofMimeType String?
  bankTransferUploadedAt DateTime?
  
  // Request Status
  status          String   @default("PENDING") 
  // PENDING -> WAITING_PAYMENT -> PAYMENT_PROOF_UPLOADED -> PAID -> APPROVED
  // or PENDING -> REJECTED, PENDING -> EXPIRED
  adminNotes      String?
  
  // Account Creation (when approved)
  password        String?  // Generated temporary password (if not provided by user)
  activatedAt     DateTime?
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  expiresAt       DateTime? // Request expires if not approved within 30 days

  // History for traceability
  history         SubscriptionRequestHistory[]
}

// Subscription Request History - tracks all changes for traceability
model SubscriptionRequestHistory {
  id              String   @id @default(cuid())
  subscriptionRequestId String
  subscriptionRequest SubscriptionRequest @relation(fields: [subscriptionRequestId], references: [id], onDelete: Cascade)
  action          String   // CREATED, VIEWED, APPROVED, REJECTED, PASSWORD_SENT, ACTIVATED
  description     String
  performedBy     String?  // Who performed the action (admin email or system)
  createdAt       DateTime @default(now())
}

// Announcement - community announcements
model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String
  type        String   @default("GENERAL") // GENERAL, URGENT, EVENT, MAINTENANCE
  priority    String   @default("NORMAL") // NORMAL, HIGH
  isActive    Boolean  @default(true)
  startDate   DateTime @default(now())
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  residenceId String
  residence   Residence @relation(fields: [residenceId], references: [id])
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
}

// Document - uploaded documents
model Document {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   // CONTRACT, INVOICE, RECEIPT, POLICY, OTHER
  fileUrl     String
  fileSize    Int?
  mimeType    String?
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  residenceId String
  residence   Residence @relation(fields: [residenceId], references: [id])
  uploadedById String
  uploadedBy  User     @relation(fields: [uploadedById], references: [id])
  
  // Optional link to apartment
  apartmentId String?
  apartment   Apartment? @relation(fields: [apartmentId], references: [id])
}

// Activity Log - tracks all actions in the system
model ActivityLog {
  id          String   @id @default(cuid())
  action      String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, APPROVE, REJECT, etc.
  target      String   // The entity type being acted upon
  targetId    String?  // The ID of the entity
  description String?  // Human-readable description
  metadata    String?  // JSON string for additional data
  
  // User info
  userId      String?
  userName    String?
  userEmail   String?
  userRole    String?
  
  // Organization context
  organizationId String?
  
  // Residence context (for admin actions)
  residenceId String?
  residenceName String?
  
  // Timestamps
  createdAt   DateTime @default(now())
}


// OwnerSettings - Global owner/platform settings including bank information
model OwnerSettings {
  id                    String   @id @default(cuid())
  
  // Bank Transfer Information
  bankAccountHolder     String?
  bankName              String?
  bankRib               String?
  bankIban              String?
  bankSwift             String?
  
  // Billing Support
  billingSupportEmail   String?
  billingSupportPhone   String?
  
  // Timestamps
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
